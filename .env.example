# ============================================================================
# smart-takeout-service · 环境变量样例（.env.example）
# ----------------------------------------------------------------------------
# 拷贝本文件为 .env 并填写真实值，.env 已在 .gitignore 中，不会被提交。
# IDE 启动时通过 EnvFile 插件或运行配置加载；命令行启动：
#   set -a; source .env; set +a; mvn -pl smart-takeout-server spring-boot:run
# ============================================================================

# --- 数据库 ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smart_takeout
DB_USERNAME=root
DB_PASSWORD=change-me

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_DB=10

# --- 阿里云 OSS ---
SMART_ALIOSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
SMART_ALIOSS_ACCESS_KEY_ID=change-me
SMART_ALIOSS_ACCESS_KEY_SECRET=change-me
SMART_ALIOSS_BUCKET_NAME=change-me

# --- 微信小程序 + 微信支付 V3 ---
SMART_WECHAT_APPID=change-me
SMART_WECHAT_SECRET=change-me
SMART_WECHAT_MCHID=change-me
SMART_WECHAT_MCH_SERIAL_NO=change-me
SMART_WECHAT_PRIVATE_KEY_FILE_PATH=/secure/pay/apiclient_key.pem
SMART_WECHAT_API_V3_KEY=change-me
SMART_WECHAT_PAY_CERT_FILE_PATH=/secure/pay/wechatpay_cert.pem
SMART_WECHAT_NOTIFY_URL=https://your-public-domain/notify/paySuccess
SMART_WECHAT_REFUND_NOTIFY_URL=https://your-public-domain/notify/refundSuccess

# --- JWT（双端密钥 + 过期时间） ---
SMART_JWT_ADMIN_SECRET_KEY=please-use-a-strong-random-secret-256bit
SMART_JWT_ADMIN_TTL=7200000
SMART_JWT_ADMIN_TOKEN_NAME=token
SMART_JWT_USER_SECRET_KEY=please-use-another-strong-random-secret-256bit
SMART_JWT_USER_TTL=7200000
SMART_JWT_USER_TOKEN_NAME=authentication

# --- 业务配置 ---
SMART_SHOP_ADDRESS=北京市海淀区上地十街10号
SMART_BAIDU_AK=change-me
